# Firebase Admin SDK service account JSON (stringified).
# Download from: Firebase Console -> Project Settings -> Service accounts -> Generate new private key
# Then paste the stringified JSON as the value (single line, no wrapping).
# Required for /api/admin/moderation/* routes (Phase 1 SEC-01).
FIREBASE_SERVICE_ACCOUNT_JSON=

# Existing vars (document for completeness)
MONGODB_URI=
SUPER_ADMIN_EMAIL=
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ANDROID_SHA256_CERT_FINGERPRINTS=
PORT=5001
